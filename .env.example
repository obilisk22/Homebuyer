GOOGLE_MAPS_API_KEY=

# Google Gemini — neighborhood overview on the Neighborhood tab
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash-lite)
GEMINI_MODEL=

# App
HOMEBUY_DB_PATH=data/homebuy.db
HOMEBUY_HOST=127.0.0.1
HOMEBUY_PORT=8080
