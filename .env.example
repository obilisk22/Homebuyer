# Optional: prefer Google Geocoding for Map pins (Nominatim works without this).
GOOGLE_MAPS_API_KEY=

# Google Gemini — Neighborhood overview/things-to-do + Financials breakdown/opinion
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash-lite)
GEMINI_MODEL=

# Census Bureau API — Map income choropleth (ACS B19013) AND Financials
# county effective property-tax fallback (ACS B25103 / B25077).
# Free signup: https://api.census.gov/data/key_signup.html
# Without this key the income toggle shows a setup message and does not crash.
CENSUS_API_KEY=

# Optional Socrata app token — higher rate limits for LA County (LAPD Socrata + Santa Monica CKAN) and Seattle crime overlays.
# https://dev.socrata.com/register (not required for light local use)
SOCRATA_APP_TOKEN=

# App
HOMEBUY_DB_PATH=data/homebuy.db
HOMEBUY_HOST=127.0.0.1
HOMEBUY_PORT=8080
