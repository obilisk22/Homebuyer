# Optional: prefer Google Geocoding for Map pins; also powers nearby Places grocery/shelter signals.
GOOGLE_MAPS_API_KEY=

# Google Gemini — Neighborhood overview/things-to-do + Financials breakdown/opinion
GEMINI_API_KEY=
# Neighborhood (and fallback) model — default gemini-3.1-flash-lite (higher free-tier RPD)
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional Financials model — default gemini-2.5-flash-lite (free-tier Search/URL tools)
GEMINI_FINANCIAL_MODEL=gemini-2.5-flash-lite

# Census Bureau API — Map ACS tract choropleths (income, home value, median age, avg kids,
# % owner-occupied, year built, gross rent, % bachelor's+) AND Financials county effective
# property-tax fallback (ACS B25103 / B25077) AND buy-vs-rent rent-growth CAGR (B25064).
# Free signup: https://api.census.gov/data/key_signup.html
# Without this key ACS map toggles show a setup message and do not crash.
CENSUS_API_KEY=

# Optional Socrata app token — higher rate limits for LA County (LAPD Socrata + Santa Monica CKAN)
# and Seattle crime overlays, and LA / Seattle / Austin building-permit lookups.
# https://dev.socrata.com/register (not required for light local use)
SOCRATA_APP_TOKEN=

# Assigned-school quality badge (Neighborhood tab) uses the free CA School
# Dashboard (CDE Academic Indicator downloadable data) + a Niche deep link —
# no API key needed.

# Missing-broadband chip (library) uses geo.fcc.gov + Living Atlas BDC block
# UniqueProviders* — no API key / FCC BDC credentials required.

# App
HOMEBUY_DB_PATH=data/homebuy.db
HOMEBUY_HOST=127.0.0.1
HOMEBUY_PORT=8080
# Desktop window: set to 1 (or pass --native). Packaged .exe defaults to native.
# HOMEBUY_NATIVE=0
# Optional fixed port for native only (default: auto-pick a free port; do not reuse 8080).
# HOMEBUY_NATIVE_PORT=
# Optional override for writable data (DB/uploads/cache). Packaged default: %LOCALAPPDATA%\Homebuy
# HOMEBUY_DATA_DIR=
